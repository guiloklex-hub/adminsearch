{
  "name": "adminsearch",
  "version": "0.2.0",
  "private": true,
  "description": "Inventário de admins locais do parque Windows — coleta via PowerShell + ScreenConnect, expansão AD/LDAP, relatórios BI.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/guiloklex-hub/adminsearch"
  },
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "dev:web": "vite",
    "build:web": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "npm run build:web && npm run build:server",
    "start": "node dist/server/index.js",
    "start:tsx": "tsx src/server/index.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/helmet": "^13.0.1",
    "@fastify/jwt": "^9.0.4",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/static": "^8.0.4",
    "argon2": "^0.41.1",
    "drizzle-orm": "^0.36.4",
    "fastify": "^5.2.1",
    "ldapts": "^7.2.1",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@tanstack/react-query": "^5.62.7",
    "@tanstack/react-router": "^1.95.0",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "drizzle-kit": "^0.30.1",
    "echarts": "^5.5.1",
    "echarts-for-react": "^3.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
