# adminsearch — exemplo de configuração
# Copie para .env e ajuste antes de subir o serviço.

NODE_ENV=production
HOST=0.0.0.0
PORT=3010

# Conexão Postgres. Envolver em aspas simples — `&` no shell quebra a URL.
# Docker compose default:
DATABASE_URL='postgresql://adminsearch_app:CHANGE_ME@postgres:5432/adminsearch'

# Senha do role `adminsearch_app` no Postgres — usada pelo docker-compose.
POSTGRES_PASSWORD=

# JWT — sessão do admin na Web UI
# openssl rand -base64 64
JWT_SECRET=

# Token Bearer usado pelo PowerShell para autenticar no /api/v1/ingest
# openssl rand -base64 32
INGEST_TOKEN=

# LDAP / Active Directory (service account READ-ONLY)
LDAP_URL=ldaps://dc01.madeiramadeira.local:636
LDAP_BIND_DN=CN=svc-adminsearch,OU=Service Accounts,DC=madeiramadeira,DC=local
LDAP_BIND_PASSWORD=
LDAP_BASE_DN=DC=madeiramadeira,DC=local
# Caminho do CA bundle PEM com o cert do AD (deixe vazio para usar truststore do sistema)
LDAP_TLS_CA_FILE=

# Operação
LOG_LEVEL=info
STALE_AGENT_DAYS=7
AD_USER_CACHE_TTL_HOURS=24
ENRICHER_POLL_MS=5000

# Cookies — seta `Secure` em produção (HTTPS atrás de reverse proxy)
COOKIE_SECURE=true
COOKIE_DOMAIN=
